
{
    "name": "ug-code/laranova",
    "description": "Postman-like API test interface for Laravel. Pre-script Faker tags, HTTP Client wrapper, SPA UI.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "api", "testing", "postman", "debug", "documentation"],
    "homepage": "https://github.com/ug-code/Laranova",
    "authors": [
        {
            "name": "ug-code",
            "homepage": "https://github.com/ug-code"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0|^13.0",
        "fakerphp/faker": "^1.23"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Laranova\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Laranova\\LaranovaServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
